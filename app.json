{
  "expo": {
    "name": "SirvaOS",
    "slug": "sirvaos-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sirvaosapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E6B68"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sirvaos.app"
    },
    "android": {
      "package": "com.sirvaos.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0E6B68"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0E6B68"
        }
      ],
      "expo-splash-screen",
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "O SirvaOS precisa da câmera para funções de check-in e foto de perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
