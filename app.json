{
  "expo": {
    "name": "SirvaOS",
    "slug": "sirvaos-app",
    "version": "1.0.2",
    "platforms": ["android"],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sirvaosapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E6B68"
    },
    "android": {
      "package": "com.sirvaos.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "edgeToEdge": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0E6B68"
      },
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0E6B68",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#0E6B68"
        }
      ],
      "expo-local-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "O SirvaOS precisa da câmera para funções de check-in e foto de perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b0bba91a-3a3f-4398-a339-24a5e7d5872c"
      }
    },
    "owner": "ridabe_2026"
  }
}
